# Vercel KV — добавляется АВТОМАТИЧЕСКИ при подключении KV-хранилища:
#   Vercel Dashboard → Storage → Create → KV → Connect to Project
# После этого эти переменные появятся сами, вручную ничего вписывать не нужно.
KV_REST_API_URL=https://xxxx.kv.vercel-storage.com
KV_REST_API_TOKEN=xxxxxxxx

# Публичный URL приложения — для кнопки "Поделиться в Telegram"
NEXT_PUBLIC_APP_URL=https://trewel.vercel.app
